APP_NAME=HubService
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://hub.localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=hub
DB_USERNAME=hub
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=pusher
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

PUSHER_APP_ID=hub-app
PUSHER_APP_KEY=hub-app-key
PUSHER_APP_SECRET=hub-app-secret
PUSHER_APP_CLUSTER=mt1



# PUSHER_HOST=localhost
PUSHER_HOST=soketi 
PUSHER_CLIENT_HOST=localhost
PUSHER_PORT=6001
PUSHER_SCHEME=http


HR_SERVICE_BASE_URL=http://hr-nginx

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=hub
RABBITMQ_PASSWORD=secret
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=employee.events
RABBITMQ_QUEUE=hub.employee.events
RABBITMQ_ROUTING_KEYS=employee.*.*
RABBITMQ_PREFETCH_COUNT=10
